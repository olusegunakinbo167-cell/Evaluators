# Server
PORT=3000

# Output directory for exported evaluation files
OUTPUT_DIR=./output

# Evaluator identity (used in export metadata)
EVALUATOR_NAME=IT Expert

# ─── LLM-as-a-Judge ───────────────────────────────────────────────────────────

# OpenAI API key for automated rubric scoring
# If unset, the judge falls back to neutral baseline scores (or MockJudgeProvider in tests)
OPENAI_API_KEY=sk-...

# Judge model (must support Structured Outputs / JSON Schema)
# Default: gpt-4o-2024-08-06
OPENAI_JUDGE_MODEL=gpt-4o-2024-08-06

# Auto-judge responses when manualScores are omitted (true|false)
AUTO_JUDGE=true

# ─── Judge concurrency / retry ────────────────────────────────────────────────

# Max parallel outbound judge requests (default: 3)
# Raise for higher throughput, lower to avoid rate limits in CI
LLM_MAX_CONCURRENCY=3

# Max retry attempts per request on transient failures (default: 3)
# Retries apply to 429 / rate_limit, 5xx, timeouts, network errors
LLM_MAX_RETRIES=3

# Base delay in ms for exponential backoff (default: 250)
LLM_RETRY_BASE_MS=250

# Maximum backoff delay cap in ms (default: 8000)
LLM_RETRY_MAX_MS=8000

# Jitter factor 0–1 added to backoff to avoid thundering herd (default: 0.25)
LLM_RETRY_JITTER=0.25
